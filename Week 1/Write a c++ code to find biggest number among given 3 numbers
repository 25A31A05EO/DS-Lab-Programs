#include <iostream>
using namespace std;

int main()
{
    int a, b, c;

    cout << "Enter three numbers: ";
    cin >> a >> b >> c;

    if (a >= b && a >= c)
        cout << "Biggest number is: " << a;
    else if (b >= a && b >= c)
        cout << "Biggest number is: " << b;
    else
        cout << "Biggest number is: " << c;

    return 0;
}
