#include <iostream>
using namespace std;

int main()
{
    string name, branch, section;
    int rollNumber;

    // Input details
    cout << "Enter Student Name: ";
    getline(cin, name);

    cout << "Enter Branch: ";
    getline(cin, branch);

    cout << "Enter Roll Number: ";
    cin >> rollNumber;

    cout << "Enter Section: ";
    cin >> section;

    // Display details
    cout << "\n--- Student Details ---" << endl;
    cout << "Name: " << name << endl;
    cout << "Branch: " << branch << endl;
    cout << "Roll Number: " << rollNumber << endl;
    cout << "Section: " << section << endl;

    return 0;
}
