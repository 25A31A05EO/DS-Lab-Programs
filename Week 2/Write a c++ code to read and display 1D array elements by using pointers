#include <iostream>
using namespace std;

int main()
{
    int n, i;
    int arr[100];
    int *ptr;

    cout << "Enter number of elements: ";
    cin >> n;

    ptr = arr;   // pointer points to first element of array

    cout << "Enter the elements: ";
    for(i = 0; i < n; i++)
    {
        cin >> *(ptr + i);
    }

    cout << "Array elements are: ";
    for(i = 0; i < n; i++)
    {
        cout << *(ptr + i) << " ";
    }

    return 0;
}
