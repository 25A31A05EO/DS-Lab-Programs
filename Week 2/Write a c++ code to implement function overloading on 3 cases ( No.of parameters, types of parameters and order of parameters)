#include <iostream>
using namespace std;

// 1. Function overloading by number of parameters
int add(int a, int b)
{
    return a + b;
}

int add(int a, int b, int c)
{
    return a + b + c;
}

// 2. Function overloading by type of parameters
float add(float a, float b)
{
    return a + b;
}

// 3. Function overloading by order of parameters
void show(int a, float b)
{
    cout << "Function with order (int, float): " << a << " " << b << endl;
}

void show(float a, int b)
{
    cout << "Function with order (float, int): " << a << " " << b << endl;
}

int main()
{
    cout << "Addition of two integers: " << add(10, 20) << endl;
    cout << "Addition of three integers: " << add(10, 20, 30) << endl;
    cout << "Addition of two floats: " << add(10.5f, 20.5f) << endl;

    show(5, 3.2f);
    show(3.2f, 5);

    return 0;
}
