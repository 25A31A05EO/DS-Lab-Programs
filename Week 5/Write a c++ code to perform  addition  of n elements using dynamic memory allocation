#include <iostream>
using namespace std; // Fixed "namescape" to "namespace"

class Addition {
private:
    int n;
    int* ptr;
    int sum;

public:
    // Constructor to initialize pointer to null
    Addition() : ptr(nullptr), n(0), sum(0) {}

    void getsize() {
        cout << "Enter number of elements: ";
        cin >> n;
        ptr = new int[n]; // Dynamic allocation
    }

    void getElements() {
        cout << "Enter " << n << " elements:" << endl;
        for (int i = 0; i < n; i++) {
            cin >> ptr[i];
        }
    }

    void calculateSum() {
        sum = 0;
        for (int i = 0; i < n; i++) {
            sum = sum + ptr[i];
        }
    }

    void displaySum() {
        cout << "Sum of elements = " << sum << endl; // Fixed 'end()' to 'endl'
    }

    // Destructor to free memory
    ~Addition() {
        delete[] ptr; 
    }
};

int main() {
    Addition obj;
    obj.getsize();
    obj.getElements();
    obj.calculateSum();
    obj.displaySum();

    return 0;
}
